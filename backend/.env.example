DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mexit
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=
TEST_AUTH_BYPASS=false

# Consumed by tests/conftest.py only (not read by app.config.Settings).
# If unset, tests fall back to DATABASE_URL above — this bootstrap pass runs
# tests against the same local Postgres instance as dev, not an isolated DB.
TEST_DATABASE_URL=
